# Binaries (anchored — bare `agent` / `server` would also match the
# cmd/agent/ and cmd/server/ source directories and silently drop any
# newly-added file under them).
/hop-agent
/hop-server
/hop-agent-linux-*
/hop-server-linux-*
/hop-agent-darwin-*
/hop-server-darwin-*
/agent
/server
spike/quic/quic-spike
spike/quic/quic-spike-arm64
spike/relay-vs-tailscale-evidence/tools/tcp-rtt-probe/tcp-rtt-probe
spike/relay-vs-tailscale-evidence/0*-*.log
spike/relay-vs-tailscale-evidence/0*-*.pcap
spike/relay-vs-tailscale-evidence/0*-*.mp4
*.exe

# Vendor (generated via `make vendor` — includes patched dependencies)
vendor/

# Frontend (generated)
frontend/node_modules/
frontend/build/
frontend/.svelte-kit/
internal/frontend/dist/
!internal/frontend/dist/.gitkeep

# Environment and secrets
.env
deploy/key.pem
deploy/*.pem

# Runtime
data/

# Performance comparison runs (scripts/perf_compare.sh output)
results/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code internal state (per-session lock files, plan caches, etc.)
.claude/

# E2E-session reference (host connection details — not secrets,
# but session-scoped and machine-specific so never committed).
.e2e-*
