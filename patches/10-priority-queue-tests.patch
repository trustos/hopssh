+// TestClassify verifies packet classification by Nebula MessageType + size.
+func TestClassify(t *testing.T) {
+	cases := []struct {
+		name string
+		pkt  []byte
+		want int // 0=interactive, 1=realtime, 2=bulk
+	}{
+		{"empty", []byte{}, 0},
+		{"handshake", []byte{0x10}, 0},                                          // type 0
+		{"message-tiny", make1byteN(0x11, 50), 0},                               // type 1, 50B
+		{"message-small", make1byteN(0x11, 199), 0},                             // type 1, just under 200
+		{"message-mid-low", make1byteN(0x11, 200), 1},                           // type 1, 200B = realtime
+		{"message-mid-high", make1byteN(0x11, 1199), 1},                         // type 1, just under 1200
+		{"message-bulk-low", make1byteN(0x11, 1200), 2},                         // type 1, 1200B = bulk
+		{"message-bulk-mtu", make1byteN(0x11, 1400), 2},                         // typical MTU
+		{"recverror", []byte{0x12}, 0},                                          // type 2
+		{"lighthouse-large", make1byteN(0x13, 1500), 0},                         // type 3 always interactive
+		{"test", []byte{0x14}, 0},                                               // type 4
+		{"closetunnel", []byte{0x15}, 0},                                        // type 5
+		{"control-large", make1byteN(0x16, 2000), 0},                            // type 6 always interactive
+		{"high-version-bits-ignored", []byte{0xf1}, 0},                          // version=0xf masked, type=1, len<200
+	}
+	for _, tc := range cases {
+		t.Run(tc.name, func(t *testing.T) {
+			if got := classify(tc.pkt); got != tc.want {
+				t.Errorf("classify(%s, len=%d) = %d, want %d", tc.name, len(tc.pkt), got, tc.want)
+			}
+		})
+	}
+}
+
+func make1byteN(first byte, n int) []byte {
+	b := make([]byte, n)
+	b[0] = first
+	return b
+}
