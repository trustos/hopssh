+// TestPriorityOrder verifies that flushed packets land in interactive→realtime→bulk
+// order regardless of WriteTo order.
+func TestPriorityOrder(t *testing.T) {
+	sendFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(sendFd)
+	if err := unix.Bind(sendFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
+	}
+
+	recvFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(recvFd)
+	if err := unix.Bind(recvFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
+	}
+	got, err := unix.Getsockname(recvFd)
+	if err != nil {
+		t.Fatal(err)
 	}
+	recvPort := uint16(got.(*unix.SockaddrInet4).Port)
+
+	c := newTestStdConn(sendFd)
+	dest := netip.AddrPortFrom(netip.AddrFrom4([4]byte{127, 0, 0, 1}), recvPort)
+
+	// Send packets in REVERSE priority: bulk first, then realtime, then interactive.
+	// After Flush they should arrive in priority order: interactive, realtime, bulk.
+	bulkPkt := make1byteN(0x11, 1300)    // type 1, 1300B → bulk
+	bulkPkt[1] = 0xB0                    // marker: bulk
+	realtimePkt := make1byteN(0x11, 500) // type 1, 500B → realtime
+	realtimePkt[1] = 0xC0                // marker: realtime
+	interactPkt := []byte{0x10, 0xA0}    // type 0 (handshake) → interactive
+
+	if err := c.WriteTo(bulkPkt, dest); err != nil {
+		t.Fatal(err)
+	}
+	if err := c.WriteTo(realtimePkt, dest); err != nil {
+		t.Fatal(err)
+	}
+	if err := c.WriteTo(interactPkt, dest); err != nil {
+		t.Fatal(err)
+	}
+
+	// Verify lane assignments
+	if len(c.laneInteract) != 1 {
+		t.Errorf("interact lane: got %d, want 1", len(c.laneInteract))
+	}
+	if len(c.laneRealtime) != 1 {
+		t.Errorf("realtime lane: got %d, want 1", len(c.laneRealtime))
+	}
+	if len(c.laneBulk) != 1 {
+		t.Errorf("bulk lane: got %d, want 1", len(c.laneBulk))
+	}
+
+	if err := c.Flush(); err != nil {
+		t.Fatal(err)
+	}
+
+	// Receive in arrival order — kernel processes msghdrX[] in order, so we
+	// should see interactive (marker 0xA0), realtime (marker 0xC0), bulk (0xB0).
+	wantOrder := []byte{0xA0, 0xC0, 0xB0}
+	buf := make([]byte, 2048)
+	for i, want := range wantOrder {
+		n, _, err := unix.Recvfrom(recvFd, buf, 0)
+		if err != nil {
+			t.Fatalf("Recvfrom #%d: %v", i, err)
+		}
+		if n < 2 || buf[1] != want {
+			t.Errorf("packet %d marker = 0x%02x (n=%d), want 0x%02x", i, buf[1], n, want)
+		}
+	}
 }
