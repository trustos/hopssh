+// TestLaneOverflowIndependence verifies that filling the data lane to capacity
+// triggers flush-and-retry without losing packets.
+func TestLaneOverflowIndependence(t *testing.T) {
+	sendFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(sendFd)
+	if err := unix.Bind(sendFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
+	}
+
+	recvFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(recvFd)
+	if err := unix.Bind(recvFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
+	}
+	got, err := unix.Getsockname(recvFd)
+	if err != nil {
+		t.Fatal(err)
+	}
+	recvPort := uint16(got.(*unix.SockaddrInet4).Port)
+
+	c := newTestStdConn(sendFd)
+	dest := netip.AddrPortFrom(netip.AddrFrom4([4]byte{127, 0, 0, 1}), recvPort)
+
+	// Fill data lane to capacity
+	dataPkt := make1byteN(0x11, 1300)
+	for i := 0; i < laneCapData; i++ {
+		if err := c.WriteTo(dataPkt, dest); err != nil {
+			t.Fatalf("data WriteTo #%d: %v", i, err)
+		}
+	}
+	if len(c.laneData) != laneCapData {
+		t.Fatalf("data lane: got %d, want %d", len(c.laneData), laneCapData)
+	}
+
+	// One more should trigger flush-and-retry
+	if err := c.WriteTo(dataPkt, dest); err != nil {
+		t.Fatalf("overflow WriteTo: %v", err)
+	}
+
+	if len(c.laneData) != 1 {
+		t.Errorf("after overflow: data lane got %d, want 1", len(c.laneData))
+	}
+
+	// Drain any pending packets
+	if err := c.Flush(); err != nil {
+		t.Fatal(err)
+	}
+}
