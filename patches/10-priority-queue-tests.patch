+// TestLaneOverflowIndependence verifies that overflowing one lane doesn't
+// affect another lane. With strict-priority drop policy, bulk overflow
+// triggers a flush but doesn't drop interactive packets.
+func TestLaneOverflowIndependence(t *testing.T) {
+	sendFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(sendFd)
+	if err := unix.Bind(sendFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
+	}
+
+	recvFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(recvFd)
+	if err := unix.Bind(recvFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
+	}
+	got, err := unix.Getsockname(recvFd)
+	if err != nil {
+		t.Fatal(err)
+	}
+	recvPort := uint16(got.(*unix.SockaddrInet4).Port)
+
+	c := newTestStdConn(sendFd)
+	dest := netip.AddrPortFrom(netip.AddrFrom4([4]byte{127, 0, 0, 1}), recvPort)
+
+	// Fill bulk lane to capacity
+	bulkPkt := make1byteN(0x11, 1300)
+	for i := 0; i < laneCapBulk; i++ {
+		if err := c.WriteTo(bulkPkt, dest); err != nil {
+			t.Fatalf("bulk WriteTo #%d: %v", i, err)
+		}
+	}
+	if len(c.laneBulk) != laneCapBulk {
+		t.Fatalf("bulk lane: got %d, want %d", len(c.laneBulk), laneCapBulk)
+	}
+
+	// One more bulk packet should trigger flush-and-retry (doesn't drop interactive)
+	if err := c.WriteTo(bulkPkt, dest); err != nil {
+		t.Fatalf("overflow WriteTo: %v", err)
+	}
+
+	// After overflow flush, bulk should have just the new packet
+	if len(c.laneBulk) != 1 {
+		t.Errorf("after overflow: bulk lane got %d, want 1", len(c.laneBulk))
+	}
+
+	// Drain any pending packets
+	if err := c.Flush(); err != nil {
+		t.Fatal(err)
+	}
+}
