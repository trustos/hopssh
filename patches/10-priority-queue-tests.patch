+// newTestStdConn builds a StdConn for use in tests (skips NewListener's bind).
+func newTestStdConn(fd int) *StdConn {
+	return &StdConn{
+		sysFd:       fd,
+		isV4:        true,
+		batch:       8,
+		laneControl: make([]sendEntry, 0, laneCapControl),
+		laneData:    make([]sendEntry, 0, laneCapData),
+		sendMsgs:    make([]msghdrX, laneCapTotal),
+		sendIovs:    make([]iovec, laneCapTotal),
+	}
+}
+
+// totalQueued returns the sum of all lane lengths. Test helper.
+func (u *StdConn) totalQueued() int {
+	return len(u.laneControl) + len(u.laneData)
+}
+
+// TestClassify verifies packet classification by Nebula MessageType.
+// Data packets (type=Message) all share one lane to preserve TCP ordering;
+// only control packets jump the queue.
+func TestClassify(t *testing.T) {
+	cases := []struct {
+		name string
+		pkt  []byte
+		want int // 0=control, 1=data
+	}{
+		{"empty", []byte{}, 0},
+		{"handshake", []byte{0x10}, 0},
+		{"message-tiny", make1byteN(0x11, 50), 1},
+		{"message-mtu", make1byteN(0x11, 1400), 1},
+		{"recverror", []byte{0x12}, 0},
+		{"lighthouse", make1byteN(0x13, 1500), 0},
+		{"test", []byte{0x14}, 0},
+		{"closetunnel", []byte{0x15}, 0},
+		{"control-msg", make1byteN(0x16, 2000), 0},
+		{"version-bits-ignored", []byte{0xf1}, 1},
+	}
+	for _, tc := range cases {
+		t.Run(tc.name, func(t *testing.T) {
+			if got := classify(tc.pkt); got != tc.want {
+				t.Errorf("classify(%s, len=%d) = %d, want %d", tc.name, len(tc.pkt), got, tc.want)
+			}
+		})
+	}
+}
+
+func make1byteN(first byte, n int) []byte {
+	b := make([]byte, n)
+	b[0] = first
+	return b
+}
+
+// TestPriorityOrder verifies control packets land before data packets in the
+// sendmsg_x batch, and data packets within the data lane preserve FIFO order.
+func TestPriorityOrder(t *testing.T) {
+	sendFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(sendFd)
+	if err := unix.Bind(sendFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
+	}
+
+	recvFd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(recvFd)
+	if err := unix.Bind(recvFd, &unix.SockaddrInet4{Port: 0, Addr: [4]byte{127, 0, 0, 1}}); err != nil {
+		t.Fatal(err)
 	}
+	got, err := unix.Getsockname(recvFd)
+	if err != nil {
+		t.Fatal(err)
+	}
+	recvPort := uint16(got.(*unix.SockaddrInet4).Port)
+
+	c := newTestStdConn(sendFd)
+	dest := netip.AddrPortFrom(netip.AddrFrom4([4]byte{127, 0, 0, 1}), recvPort)
+
+	// Order: data1, data2, control. After Flush, expect: control, data1, data2.
+	data1 := make1byteN(0x11, 1300)
+	data1[1] = 0xD1
+	data2 := make1byteN(0x11, 1300)
+	data2[1] = 0xD2
+	controlPkt := []byte{0x10, 0xC0}
+
+	if err := c.WriteTo(data1, dest); err != nil {
+		t.Fatal(err)
+	}
+	if err := c.WriteTo(data2, dest); err != nil {
+		t.Fatal(err)
+	}
+	if err := c.WriteTo(controlPkt, dest); err != nil {
+		t.Fatal(err)
+	}
+
+	if len(c.laneControl) != 1 {
+		t.Errorf("control lane: got %d, want 1", len(c.laneControl))
+	}
+	if len(c.laneData) != 2 {
+		t.Errorf("data lane: got %d, want 2", len(c.laneData))
+	}
+
+	if err := c.Flush(); err != nil {
+		t.Fatal(err)
+	}
+
+	// Expect: control (0xC0), then data1 (0xD1), then data2 (0xD2)
+	wantOrder := []byte{0xC0, 0xD1, 0xD2}
+	buf := make([]byte, 2048)
+	for i, want := range wantOrder {
+		n, _, err := unix.Recvfrom(recvFd, buf, 0)
+		if err != nil {
+			t.Fatalf("Recvfrom #%d: %v", i, err)
+		}
+		if n < 2 || buf[1] != want {
+			t.Errorf("packet %d marker = 0x%02x (n=%d), want 0x%02x", i, buf[1], n, want)
+		}
+	}
 }
