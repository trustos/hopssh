+//go:build !darwin || !cgo || e2e_testing
+// +build !darwin !cgo e2e_testing
+
+package nebula
+
+// applyOSThreadHints — no-op stub used when CGO is unavailable
+// (non-darwin platforms, darwin builds with CGO_ENABLED=0 such as a
+// CI cross-compile from Linux, or e2e_testing). The real CGO
+// implementation lives in qos_hint_darwin.go and only compiles when
+// darwin && cgo && !e2e_testing.
+//
+// CI implication: a CI cross-compile with CGO_ENABLED=0 builds the
+// darwin binary with this stub and the binary will NOT carry the
+// −17 % RTT QoS gain. To put the gain into the released binary, CI
+// must build darwin on a macos-latest runner with CGO_ENABLED=1 —
+// see .github/workflows/release.yml.
+func applyOSThreadHints() {}
