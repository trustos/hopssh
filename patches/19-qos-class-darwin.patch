+//go:build darwin && cgo && !e2e_testing
+// +build darwin,cgo,!e2e_testing
+
+package udp
+
+/*
+#include <pthread.h>
+#include <sys/qos.h>
+*/
+import "C"
+
+import "os"
+
+// applyOSThreadHints applies a macOS QoS class to the CURRENT OS
+// thread, if requested by the HOPSSH_QOS environment variable.
+// Same opt-in mechanism as the nebula-package equivalent — see
+// vendor/.../nebula/qos_hint_darwin.go for the rationale (hopssh
+// patch 19) and the empirical A/B/A data.
+//
+// This is duplicated rather than imported because the udp package
+// must not depend on the nebula package (nebula imports udp, not
+// the other way around). The two functions are intentionally
+// identical and trivially short.
+//
+// Default-on for darwin (USER_INTERACTIVE). HOPSSH_QOS=off to disable.
+//
+// Build constraint requires `cgo` so CI cross-compiles with
+// CGO_ENABLED=0 fall through to the stub in qos_hint_other.go
+// instead of failing with "undefined: applyOSThreadHints".
+func applyOSThreadHints() {
+	switch os.Getenv("HOPSSH_QOS") {
+	case "off":
+		return
+	case "initiated":
+		C.pthread_set_qos_class_self_np(C.QOS_CLASS_USER_INITIATED, 0)
+	default:
+		C.pthread_set_qos_class_self_np(C.QOS_CLASS_USER_INTERACTIVE, 0)
+	}
+}
