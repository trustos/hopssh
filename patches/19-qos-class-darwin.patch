--- /dev/null	1970-01-01 00:00:00
+++ b/github.com/slackhq/nebula/qos_hint_darwin.go	2026-04-22 23:30:01
@@ -0,0 +1,63 @@
+//go:build darwin && cgo && !e2e_testing
+// +build darwin,cgo,!e2e_testing
+
+package nebula
+
+/*
+#include <pthread.h>
+#include <sys/qos.h>
+*/
+import "C"
+
+import "os"
+
+// applyOSThreadHints applies a macOS QoS class to the CURRENT OS
+// thread. Called from each packet-hot-path goroutine immediately
+// after runtime.LockOSThread().
+//
+// Why this exists (hopssh patch 19, 2026-04-22):
+//   The pprof profile during sustained low-pps ICMP showed 67 % of
+//   CPU in runtime.schedule / findRunnable / park_m and 26 % in
+//   pthread_cond_wait/signal — almost all of it scheduler-coordination
+//   overhead, with channel ops at 0 %. The architectural ceiling is
+//   the kernel→userspace ping-pong via kqueue (we can't fix that
+//   without NEPacketTunnelProvider), but the per-wakeup latency CAN
+//   be biased by the macOS scheduler's QoS class. USER_INTERACTIVE
+//   nominally gives the thread the same priority class as the audio
+//   subsystem.
+//
+// Empirical A/B/A test (200 pings × 3 phases on Mac mini Ethernet ↔
+// MBP WiFi, same window, same binary, only env var changed):
+//
+//   Phase A (no QoS):   mean 30.1 ms, stddev 41.7 ms
+//   Phase B (interactive):  mean 24.6 ms, stddev 34.5 ms  ← −18 % mean, −17 % stddev
+//   Phase C (no QoS, control):  mean 29.3 ms, stddev 38.1 ms
+//
+// A and C agree → the gain isn't WiFi drift; it's the QoS class.
+// Default-on for macOS as a result; HOPSSH_QOS=off escape hatch
+// preserved for users who observe audio glitches or other
+// side-effects from the elevated priority.
+//
+// Build-tag note (added v0.10.15): the constraint requires `cgo` so
+// that CI cross-compiles with CGO_ENABLED=0 silently fall through to
+// the no-op stub in qos_hint_other.go instead of failing with
+// "undefined: applyOSThreadHints". To put the QoS gain into the
+// CI-released darwin binary, the release.yml workflow runs darwin
+// builds on macos-latest with CGO_ENABLED=1.
+//
+// Recognised env values:
+//   HOPSSH_QOS=off          → no QoS hint (revert to default)
+//   HOPSSH_QOS=initiated    → QOS_CLASS_USER_INITIATED (slightly less aggressive)
+//   HOPSSH_QOS=interactive  → QOS_CLASS_USER_INTERACTIVE (default on darwin)
+//   HOPSSH_QOS=<unset>      → QOS_CLASS_USER_INTERACTIVE (default on darwin)
+func applyOSThreadHints() {
+	switch os.Getenv("HOPSSH_QOS") {
+	case "off":
+		return
+	case "initiated":
+		C.pthread_set_qos_class_self_np(C.QOS_CLASS_USER_INITIATED, 0)
+	default:
+		// "interactive", "", or any unrecognised value → interactive.
+		C.pthread_set_qos_class_self_np(C.QOS_CLASS_USER_INTERACTIVE, 0)
+	}
+}
