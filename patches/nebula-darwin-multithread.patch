# Patch: Decoupled multi-reader UDP for macOS
# Applied to: github.com/slackhq/nebula v1.10.3
#
# Decouples UDP and TUN routine counts so macOS can have multiple UDP
# reader goroutines (SO_REUSEPORT) even without TUN multiqueue.
# On macOS with routines=4: 4 goroutines read/decrypt from UDP in parallel,
# all writing to a single mutex-protected TUN device.
#
# Three changes:
# 1. interface.go: Separate tunRoutines from routines. UDP readers that
#    exceed TUN queues share readers[0]. listenIn only launches tunRoutines.
# 2. tun_darwin.go: Add sync.Mutex to Write() for safe concurrent access
#    from multiple listenOut goroutines sharing the same TUN fd.
# 3. udp_darwin.go: Enable SupportsMultipleReaders() — macOS SO_REUSEPORT
#    already works (used in NewListenConfig when multi=true).

--- a/github.com/slackhq/nebula/interface.go
+++ b/github.com/slackhq/nebula/interface.go
@@ -69,6 +69,7 @@
 	dropLocalBroadcast    bool
 	dropMulticast         bool
 	routines              int
+	tunRoutines           int
 	disconnectInvalid     atomic.Bool
 	closed                atomic.Bool
 	relayManager          *relayManager
@@ -223,25 +224,37 @@
 		WithField("boringcrypto", boringEnabled()).
 		Info("Nebula interface is active")

-	if f.routines > 1 {
-		if !f.inside.SupportsMultiqueue() || !f.outside.SupportsMultipleReaders() {
-			f.routines = 1
-			f.l.Warn("routines is not supported on this platform, falling back to a single routine")
-		}
+	f.tunRoutines = f.routines
+	if f.tunRoutines > 1 && !f.inside.SupportsMultiqueue() {
+		f.tunRoutines = 1
 	}
+	if f.routines > 1 && !f.outside.SupportsMultipleReaders() {
+		f.routines = 1
+	}
+	if f.tunRoutines > f.routines {
+		f.tunRoutines = f.routines
+	}

 	metrics.GetOrRegisterGauge("routines", nil).Update(int64(f.routines))

-	// Prepare n tun queues
+	// Prepare TUN queues: create tunRoutines real queues, share readers[0]
+	// for any extra UDP routines that lack their own TUN queue.
 	var reader io.ReadWriteCloser = f.inside
 	for i := 0; i < f.routines; i++ {
-		if i > 0 {
+		if i > 0 && i < f.tunRoutines {
 			reader, err = f.inside.NewMultiQueueReader()
 			if err != nil {
 				f.l.Fatal(err)
 			}
+		} else if i >= f.tunRoutines {
+			reader = f.readers[0]
 		}
 		f.readers[i] = reader
+	}
+
+	if f.routines > f.tunRoutines {
+		f.l.WithField("udpRoutines", f.routines).WithField("tunRoutines", f.tunRoutines).
+			Info("Decoupled routines: multiple UDP readers sharing single TUN writer")
 	}

 	if err := f.inside.Activate(); err != nil {
@@ -251,13 +264,14 @@
 }

 func (f *Interface) run() {
-	// Launch n queues to read packets from udp
+	// Launch UDP reader goroutines (may exceed TUN queues on platforms
+	// with SO_REUSEPORT but no TUN multiqueue, e.g. macOS).
 	for i := 0; i < f.routines; i++ {
 		go f.listenOut(i)
 	}

-	// Launch n queues to read packets from tun dev
-	for i := 0; i < f.routines; i++ {
+	// Launch TUN reader goroutines (1 per TUN queue).
+	for i := 0; i < f.tunRoutines; i++ {
 		go f.listenIn(f.readers[i], i)
 	}
 }

