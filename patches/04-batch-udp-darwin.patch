+func (u *StdConn) PrepareRawMessages(n int) ([]msghdrX, [][]byte, [][]byte) {
+	msgs := make([]msghdrX, n)
+	buffers := make([][]byte, n)
+	names := make([][]byte, n)
+
+	for i := range msgs {
+		buffers[i] = make([]byte, MTU)
+		names[i] = make([]byte, unix.SizeofSockaddrInet6)
+
+		msgs[i].Iov = &iovec{
+			Base: &buffers[i][0],
+			Len:  uint64(len(buffers[i])),
+		}
+		msgs[i].Iovlen = 1
+		msgs[i].Name = &names[i][0]
+		msgs[i].Namelen = uint32(unix.SizeofSockaddrInet6)
+	}
+
+	return msgs, buffers, names
+}
+
+func (u *StdConn) ReadMulti(msgs []msghdrX) (int, error) {
+	for {
+		n, _, err := unix.Syscall6(
+			unix.SYS_RECVMSG_X,
+			uintptr(u.sysFd),
+			uintptr(unsafe.Pointer(&msgs[0])),
+			uintptr(len(msgs)),
+			0,
+			0,
+			0,
+		)
+		if err != 0 {
+			return 0, &net.OpError{Op: "recvmsg_x", Err: err}
+		}
+		return int(n), nil
+	}
+}
+
+func (u *StdConn) ReadSingle(msgs []msghdrX) (int, error) {
+	for {
+		n, _, err := unix.Syscall6(
+			unix.SYS_RECVMSG,
+			uintptr(u.sysFd),
+			uintptr(unsafe.Pointer(&msgs[0])),
+			0,
+			0,
+			0,
+			0,
+		)
+		if err != 0 {
+			return 0, &net.OpError{Op: "recvmsg", Err: err}
+		}
+		msgs[0].Datalen = uint64(n)
+		return 1, nil
+	}
+}
+
+func (u *StdConn) ListenOut(r EncReader) {
+	msgs, buffers, names := u.PrepareRawMessages(u.batch)
+	read := u.ReadMulti
+	if u.batch == 1 {
+		read = u.ReadSingle
+	}
+
+	var ip netip.Addr
+	for {
+		n, err := read(msgs)
+		if err != nil {
+			u.l.WithError(err).Debug("udp socket is closed, exiting read loop")
+			return
+		}
