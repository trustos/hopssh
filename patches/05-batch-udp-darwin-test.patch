+func TestMsghdrXLayout(t *testing.T) {
+	var m msghdrX
+	if got := unsafe.Sizeof(m); got != 56 {
+		t.Fatalf("sizeof(msghdrX) = %d, want 56", got)
+	}
+
+	if got := unsafe.Offsetof(m.Name); got != 0 {
+		t.Fatalf("offsetof(Name) = %d, want 0", got)
+	}
+	if got := unsafe.Offsetof(m.Namelen); got != 8 {
+		t.Fatalf("offsetof(Namelen) = %d, want 8", got)
+	}
+	if got := unsafe.Offsetof(m.Iov); got != 16 {
+		t.Fatalf("offsetof(Iov) = %d, want 16", got)
+	}
+	if got := unsafe.Offsetof(m.Iovlen); got != 24 {
+		t.Fatalf("offsetof(Iovlen) = %d, want 24", got)
+	}
+	if got := unsafe.Offsetof(m.Control); got != 32 {
+		t.Fatalf("offsetof(Control) = %d, want 32", got)
+	}
+	if got := unsafe.Offsetof(m.Controllen); got != 40 {
+		t.Fatalf("offsetof(Controllen) = %d, want 40", got)
+	}
+	if got := unsafe.Offsetof(m.Flags); got != 44 {
+		t.Fatalf("offsetof(Flags) = %d, want 44", got)
+	}
+	if got := unsafe.Offsetof(m.Datalen); got != 48 {
+		t.Fatalf("offsetof(Datalen) = %d, want 48", got)
+	}
+}
