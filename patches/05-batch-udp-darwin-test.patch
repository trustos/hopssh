+func TestSyscallNumbers(t *testing.T) {
+	if unix.SYS_RECVMSG_X != 480 {
+		t.Fatalf("SYS_RECVMSG_X = %d, want 480", unix.SYS_RECVMSG_X)
+	}
+	if unix.SYS_SENDMSG_X != 481 {
+		t.Fatalf("SYS_SENDMSG_X = %d, want 481", unix.SYS_SENDMSG_X)
+	}
+}
