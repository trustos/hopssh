+func TestBatchListenOutRoundTrip(t *testing.T) {
+	fd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(fd)
+
+	sa := &unix.SockaddrInet4{Port: 0}
+	sa.Addr = [4]byte{127, 0, 0, 1}
+	if err := unix.Bind(fd, sa); err != nil {
+		t.Fatal(err)
+	}
+
+	got, err := unix.Getsockname(fd)
+	if err != nil {
+		t.Fatal(err)
+	}
+	boundAddr := got.(*unix.SockaddrInet4)
+
+	sender, err := net.DialUDP("udp4", nil, &net.UDPAddr{
+		IP:   net.IP(boundAddr.Addr[:]),
+		Port: boundAddr.Port,
+	})
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer sender.Close()
+
+	for i := 0; i < 5; i++ {
+		if _, err := sender.Write([]byte{byte(i), byte(i + 10)}); err != nil {
+			t.Fatal(err)
+		}
+	}
+
+	c := &StdConn{sysFd: fd, isV4: true, batch: 16}
+	msgs, buffers, names := c.PrepareRawMessages(16)
+
+	// recvmsg_x returns whatever is available, so loop until we get all 5
+	total := 0
+	for total < 5 {
+		n, err := c.ReadMulti(msgs[total:])
+		if err != nil {
+			t.Fatal(err)
+		}
+		total += n
+	}
+
+	for i := 0; i < total; i++ {
+		data := buffers[i][:msgs[i].Datalen]
+		if len(data) != 2 || data[0] != byte(i) || data[1] != byte(i+10) {
+			t.Errorf("packet %d = %v, want [%d %d]", i, data, i, i+10)
+		}
+
+		ip, _ := netip.AddrFromSlice(names[i][4:8])
+		if !ip.IsLoopback() {
+			t.Errorf("packet %d source IP = %v, want loopback", i, ip)
+		}
+	}
+}
