+func TestSendmsgXRecvmsgXRoundTrip(t *testing.T) {
+	fd, err := unix.Socket(unix.AF_INET, unix.SOCK_DGRAM, unix.IPPROTO_UDP)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer unix.Close(fd)
+
+	sa := &unix.SockaddrInet4{Port: 0}
+	sa.Addr = [4]byte{127, 0, 0, 1}
+	if err := unix.Bind(fd, sa); err != nil {
+		t.Fatal(err)
+	}
+
+	got, err := unix.Getsockname(fd)
+	if err != nil {
+		t.Fatal(err)
+	}
+	boundPort := got.(*unix.SockaddrInet4).Port
+
+	payloads := []string{"hello", "batch", "udp"}
+	sendMsgs := make([]msghdrX, len(payloads))
+	sendIovs := make([]iovec, len(payloads))
+	sendBufs := make([][]byte, len(payloads))
+	sendNames := make([]unix.RawSockaddrInet4, len(payloads))
+
+	for i, p := range payloads {
+		sendBufs[i] = []byte(p)
+		sendIovs[i] = iovec{Base: &sendBufs[i][0], Len: uint64(len(sendBufs[i]))}
+
+		sendNames[i].Len = unix.SizeofSockaddrInet4
+		sendNames[i].Family = unix.AF_INET
+		sendNames[i].Addr = [4]byte{127, 0, 0, 1}
+		binary.BigEndian.PutUint16((*[2]byte)(unsafe.Pointer(&sendNames[i].Port))[:], uint16(boundPort))
+
+		sendMsgs[i] = msghdrX{
+			Name:    (*byte)(unsafe.Pointer(&sendNames[i])),
+			Namelen: unix.SizeofSockaddrInet4,
+			Iov:     &sendIovs[i],
+			Iovlen:  1,
+		}
+	}
+
+	sent, _, errno := unix.Syscall6(
+		unix.SYS_SENDMSG_X,
+		uintptr(fd),
+		uintptr(unsafe.Pointer(&sendMsgs[0])),
+		uintptr(len(sendMsgs)),
+		0, 0, 0,
+	)
+	if errno != 0 {
+		t.Fatalf("sendmsg_x failed: %v", errno)
+	}
+	if int(sent) != len(payloads) {
+		t.Fatalf("sendmsg_x sent %d, want %d", sent, len(payloads))
+	}
+
+	// Receive via recvmsg_x
+	recvMsgs := make([]msghdrX, 8)
+	recvBufs := make([][]byte, 8)
+	recvNames := make([][]byte, 8)
+	for i := range recvMsgs {
+		recvBufs[i] = make([]byte, 1024)
+		recvNames[i] = make([]byte, unix.SizeofSockaddrInet6)
+		recvMsgs[i] = msghdrX{
+			Name:    &recvNames[i][0],
+			Namelen: uint32(unix.SizeofSockaddrInet6),
+			Iov:     &iovec{Base: &recvBufs[i][0], Len: uint64(len(recvBufs[i]))},
+			Iovlen:  1,
+		}
+	}
+
+	totalRecvd := 0
+	for totalRecvd < len(payloads) {
+		recvd, _, errno := unix.Syscall6(
+			unix.SYS_RECVMSG_X,
+			uintptr(fd),
+			uintptr(unsafe.Pointer(&recvMsgs[totalRecvd])),
+			uintptr(len(recvMsgs)-totalRecvd),
+			0, 0, 0,
+		)
+		if errno != 0 {
+			t.Fatalf("recvmsg_x failed: %v", errno)
+		}
+		totalRecvd += int(recvd)
+	}
+
+	for i := 0; i < totalRecvd; i++ {
+		data := string(recvBufs[i][:recvMsgs[i].Datalen])
+		if data != payloads[i] {
+			t.Errorf("packet %d = %q, want %q", i, data, payloads[i])
+		}
+
+		ip, _ := netip.AddrFromSlice(recvNames[i][4:8])
+		port := binary.BigEndian.Uint16(recvNames[i][2:4])
+		if !ip.IsLoopback() {
+			t.Errorf("packet %d source IP = %v, want loopback", i, ip)
+		}
+		if port != uint16(boundPort) {
+			t.Errorf("packet %d source port = %d, want %d", i, port, boundPort)
+		}
+	}
+}
