+// classify returns the lane for a given outgoing packet. Two reads, no crypto:
+// b[0] holds the Nebula MessageType (low 4 bits, plaintext header), and len(b)
+// gives total wire size.
+func classify(b []byte) int {
+	// 0=interactive, 1=realtime, 2=bulk
+	if len(b) == 0 {
+		return 0
+	}
+	if b[0]&0x0f != nebulaMessageType {
+		return 0 // control / handshake / lighthouse / test / closetunnel
+	}
+	if len(b) < sizeInteractiveMax {
+		return 0
+	}
+	if len(b) < sizeRealtimeMax {
+		return 1
+	}
+	return 2
+}
