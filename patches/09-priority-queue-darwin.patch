+// appendLane copies queued entries from a lane into u.sendMsgs/u.sendIovs
+// starting at index `start`, then resets the lane. Returns the new write index.
+// Caller must hold u.sendMu.
+func (u *StdConn) appendLane(start int, lane *[]sendEntry) int {
+	n := len(*lane)
+	for i := 0; i < n; i++ {
+		entry := &(*lane)[i]
+		dst := start + i
+		u.sendIovs[dst] = iovec{
+			Base: &entry.data[0],
+			Len:  uint64(entry.dataLen),
+		}
+		msg := &u.sendMsgs[dst]
+		msg.Name = &entry.name[0]
+		msg.Namelen = entry.nameLen
+		msg.Iov = &u.sendIovs[dst]
+		msg.Iovlen = 1
+		msg.Control = nil
+		msg.Controllen = 0
+		msg.Flags = 0
+		msg.Datalen = 0
+	}
+	*lane = (*lane)[:0]
+	return start + n
+}
