+// isAddrInRanges reports whether addr is contained in any of the
+// preferred_ranges prefixes. Helper for handleHostRoaming so the
+// per-packet path doesn't allocate. Exported via lower-case for tests
+// in the same package only.
+func isAddrInRanges(addr netip.Addr, ranges []netip.Prefix) bool {
+	if !addr.IsValid() {
+		return false
+	}
+	for _, r := range ranges {
+		if r.Contains(addr) {
+			return true
+		}
+	}
+	return false
+}
