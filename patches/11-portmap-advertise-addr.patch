--- a/github.com/slackhq/nebula/lighthouse.go
+++ b/github.com/slackhq/nebula/lighthouse.go
@@ -160,6 +160,59 @@
 	return *lh.advertiseAddrs.Load()
 }
 
+// AddAdvertiseAddr adds a dynamically-discovered public endpoint (e.g. a
+// UPnP/NAT-PMP port mapping on the home router) to the set of addresses
+// we advertise to the lighthouse. Safe for concurrent use. De-dupes.
+// The next SendUpdate tick (default 10 s) propagates to peers.
+//
+// Added by hopssh patch 11.
+func (lh *LightHouse) AddAdvertiseAddr(addr netip.AddrPort) {
+	if !addr.IsValid() {
+		return
+	}
+	for {
+		cur := lh.advertiseAddrs.Load()
+		for _, a := range *cur {
+			if a == addr {
+				return
+			}
+		}
+		next := make([]netip.AddrPort, 0, len(*cur)+1)
+		next = append(next, *cur...)
+		next = append(next, addr)
+		if lh.advertiseAddrs.CompareAndSwap(cur, &next) {
+			lh.l.WithField("addr", addr).Info("lighthouse: added dynamic advertise_addr")
+			return
+		}
+	}
+}
+
+// RemoveAdvertiseAddr is the inverse of AddAdvertiseAddr. No-op if the
+// address isn't present.
+//
+// Added by hopssh patch 11.
+func (lh *LightHouse) RemoveAdvertiseAddr(addr netip.AddrPort) {
+	for {
+		cur := lh.advertiseAddrs.Load()
+		next := make([]netip.AddrPort, 0, len(*cur))
+		changed := false
+		for _, a := range *cur {
+			if a == addr {
+				changed = true
+				continue
+			}
+			next = append(next, a)
+		}
+		if !changed {
+			return
+		}
+		if lh.advertiseAddrs.CompareAndSwap(cur, &next) {
+			lh.l.WithField("addr", addr).Info("lighthouse: removed dynamic advertise_addr")
+			return
+		}
+	}
+}
+
 func (lh *LightHouse) GetRelaysForMe() []netip.Addr {
 	return *lh.relaysForMe.Load()
 }
